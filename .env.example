# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# WARNING: SUPABASE_SERVICE_ROLE_KEY bypasses RLS. Server-side only. Never expose to client.

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
SITE_PASSWORD=          # Set to password-protect the entire site (leave blank to disable)

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@yourdomain.com

# ── SMS (Twilio) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Import API ────────────────────────────────────────────────
# Used to authenticate automated scraper pipeline POSTs to /api/import/ingest
IMPORT_API_KEY=generate-a-long-random-secret-here
